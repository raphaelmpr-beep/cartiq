{
  "version": 2,
  "builds": [
    {
      "src": "dist/vercel-handler.cjs",
      "use": "@vercel/node",
      "config": { "maxLambdaSize": "50mb" }
    },
    {
      "src": "dist/public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "dist/vercel-handler.cjs" },
    { "src": "/sitemap.xml", "dest": "dist/vercel-handler.cjs" },
    { "src": "/robots.txt", "dest": "dist/vercel-handler.cjs" },
    { "src": "/llms.txt", "dest": "dist/vercel-handler.cjs" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "dist/public/index.html" }
  ],
  "env": {
    "NODE_ENV": "production",
    "VERCEL": "1"
  }
}
