# CartIQ Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Server
PORT=5000
NODE_ENV=development

# Admin
# Change this before any public deployment!
ADMIN_TOKEN=cartiq2024

# Database
# SQLite path (default). For production, replace with a Postgres URL:
# DATABASE_URL=postgresql://user:password@host:5432/cartiq
DATABASE_URL=./data.db
