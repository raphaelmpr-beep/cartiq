# CartIQ Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Server
PORT=5000
NODE_ENV=development

# Admin
# REQUIRED. The server refuses to start if this is unset.
# Generate a strong random value:
#   python3 -c "import secrets, string; print(''.join(secrets.choice(string.ascii_letters+string.digits+'-_') for _ in range(48)))"
# Do NOT commit the real value. In production this must be set in the hosting
# provider's environment (e.g. Vercel Project Settings → Environment Variables).
ADMIN_PASSWORD=

# Database
# SQLite path (default). For production, replace with a Postgres URL:
# DATABASE_URL=postgresql://user:password@host:5432/cartiq
DATABASE_URL=./data.db
